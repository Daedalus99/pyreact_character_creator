{
  "name": "pyreact-character-creator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:backend\" \"wait-on http://127.0.0.1:5173 http://127.0.0.1:5000/api/health && npm run dev:electron\"",
    "dev:frontend": "vite",
    "dev:backend": "python backend/app.py",
    "dev:electron": "electron .",
    "build": "vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^34.0.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
